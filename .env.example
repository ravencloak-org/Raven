# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=raven
POSTGRES_PASSWORD=changeme
POSTGRES_DB=raven
DATABASE_URL=postgresql://raven:changeme@postgres:5432/raven?sslmode=disable

# ─── Valkey ───────────────────────────────────────────────────────────────────
VALKEY_URL=redis://valkey:6379/0

# ─── SuperTokens ─────────────────────────────────────────────────────────────
SUPERTOKENS_API_KEY=supertokens-dev-key-replace-me

# Google OAuth (for SuperTokens social login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Cloudflare Tunnels (production only)
CF_TUNNEL_TOKEN=

# ─── Raven API ────────────────────────────────────────────────────────────────
RAVEN_SERVER_PORT=8081
RAVEN_DATABASE_URL=${DATABASE_URL}
RAVEN_VALKEY_URL=${VALKEY_URL}
RAVEN_GRPC_WORKER_ADDR=python-worker:50051

# ─── SeaweedFS ────────────────────────────────────────────────────────────────
SEAWEEDFS_FILER_URL=http://seaweedfs-filer:8888

# ─── OpenObserve ──────────────────────────────────────────────────────────────
ZO_ROOT_USER_EMAIL=admin@raven.local
ZO_ROOT_USER_PASSWORD=changeme

# ─── AI Worker: Memory & Web Search ─────────────────────────────────────────
# Set RAVEN_MEMORY_DIR to a persistent path to enable per-session memory.
# In Docker, mount a volume here so memories survive container restarts.
RAVEN_MEMORY_DIR=/var/raven/memories
# Set to true to let Claude supplement RAG answers with live web search results.
RAVEN_ENABLE_WEB_SEARCH=false

# ─── LLM Provider API Keys (BYOK) ───────────────────────────────────────────
# Used by both the dev-agent script and tenant BYOK LLM integrations
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# COHERE_API_KEY=...

# ─── Hyperswitch + Razorpay (India payments) ─────────────────────────────────
# Hyperswitch is the payment orchestrator; Razorpay is the gateway for UPI/card.
# Obtain keys from your Hyperswitch dashboard (https://app.hyperswitch.io).
# For sandbox testing use: https://sandbox.hyperswitch.io
RAVEN_HYPERSWITCH_BASE_URL=https://sandbox.hyperswitch.io
RAVEN_HYPERSWITCH_API_KEY=REPLACE_WITH_YOUR_HYPERSWITCH_API_KEY
# Secret used to verify HMAC-SHA256 signatures on incoming webhook calls.
RAVEN_HYPERSWITCH_WEBHOOK_SECRET=REPLACE_WITH_YOUR_HYPERSWITCH_WEBHOOK_SECRET
# Razorpay public key ID — surfaced to the frontend for checkout SDK initialisation.
RAVEN_HYPERSWITCH_RAZORPAY_KEY_ID=REPLACE_WITH_YOUR_RAZORPAY_KEY_ID

# ─── PostHog (opt-in: leave empty to disable) ────────────────────────────────
# RAVEN_POSTHOG_API_KEY=phc_your_project_api_key
# RAVEN_POSTHOG_HOST=https://us.i.posthog.com

# ─── OpenTelemetry ────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://openobserve:5081

# ─── LiveKit (WebRTC media server) ──────────────────────────────────────────
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret
RAVEN_LIVEKIT_API_URL=http://livekit-server:7880
# nosemgrep: javascript.lang.security.detect-insecure-websocket.detect-insecure-websocket -- dev-only placeholder; prod uses wss://
RAVEN_LIVEKIT_WS_URL=ws://livekit-server:7880
RAVEN_LIVEKIT_API_KEY=${LIVEKIT_API_KEY}
RAVEN_LIVEKIT_API_SECRET=${LIVEKIT_API_SECRET}

# ─── Traefik / ACME SSL ──────────────────────────────────────────────────────
# Domain name for Traefik Host() routing rules
RAVEN_DOMAIN=raven.example.com
# Certificate resolver: "letsencrypt" for prod, leave empty for dev (self-signed)
TRAEFIK_CERT_RESOLVER=letsencrypt
# ACME email for Let's Encrypt registration
ACME_EMAIL=admin@example.com
# DNS-01 challenge provider (cloudflare, route53, digitalocean, etc.)
ACME_DNS_PROVIDER=cloudflare
# ACME CA server (use staging for testing):
#   Staging: https://acme-staging-v02.api.letsencrypt.org/directory
#   Production: https://acme-v02.api.letsencrypt.org/directory
ACME_CA_SERVER=https://acme-v02.api.letsencrypt.org/directory
# Cloudflare DNS credentials (if using cloudflare provider)
CF_API_EMAIL=
CF_DNS_API_TOKEN=

# ─── pgBackRest Backup ───────────────────────────────────────────────────────
# Override backup repository path (default: /var/lib/pgbackrest)
PGBACKREST_REPO1_PATH=/var/lib/pgbackrest

# ─── AWS SES (transactional email — summary emails, M9 #257) ─────────────
# India-based deployment: default region is ap-south-1 (Mumbai).
# These are SES SMTP credentials, NOT regular IAM access keys. Generate via
# AWS Console → SES → SMTP settings.
AWS_SES_REGION=ap-south-1
AWS_SES_FROM_ADDRESS=summaries@mail.ravencloak.io
AWS_SES_FROM_NAME=Raven
AWS_SES_SMTP_USERNAME=
AWS_SES_SMTP_PASSWORD=

# ─── Email summary job (M9 #257) ─────────────────────────────────────────
# Public URL where the frontend lives — used to build deep-links in emails.
RAVEN_FRONTEND_BASE_URL=https://app.ravencloak.io
# Shown as the Reply-To / footer contact address.
RAVEN_SUPPORT_ADDRESS=support@ravencloak.io
# Public URL of the one-click unsubscribe endpoint (proxied by the API server).
RAVEN_UNSUBSCRIBE_BASE_URL=https://api.ravencloak.io/api/v1/notifications/unsubscribe
# HMAC-SHA256 secret for signing unsubscribe tokens (>= 32 random bytes).
# Generate with: openssl rand -hex 32
UNSUBSCRIBE_TOKEN_SECRET=
# AI worker FastAPI base URL (POST /internal/summarize).
RAVEN_AI_WORKER_HTTP_URL=http://ai-worker:8090
# The AI worker reuses ANTHROPIC_API_KEY from the LLM Provider API Keys
# section above — do NOT redeclare it here. Claude Haiku is recommended
# for cost/latency on summary generation.
RAVEN_SUMMARY_MODEL=claude-haiku-4-5

# ─── Resilience: HTTP server + AI worker ──────────────────────────────────
# All accept Go time.Duration syntax (e.g. 5s, 500ms, 2m).
RAVEN_HTTP_READ_HEADER_TIMEOUT=5s
RAVEN_HTTP_READ_TIMEOUT=30s
RAVEN_HTTP_WRITE_TIMEOUT=60s
RAVEN_HTTP_IDLE_TIMEOUT=120s

RAVEN_AI_WORKER_TIMEOUT=5s
RAVEN_AI_WORKER_BREAKER_THRESHOLD=5
RAVEN_AI_WORKER_BREAKER_COOLDOWN=30s
