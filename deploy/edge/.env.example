# ─── Raven Edge Deployment Environment Variables ─────────────────────────────
# Copy this file to the project root as .env.edge and fill in your values.
#
#   cp deploy/edge/.env.example .env.edge

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_USER=raven
POSTGRES_PASSWORD=changeme
POSTGRES_DB=raven
DATABASE_URL=postgresql://raven:changeme@postgres:5432/raven?sslmode=disable

# ─── Raven API ───────────────────────────────────────────────────────────────
RAVEN_SERVER_PORT=8080

# Remote AI worker gRPC address — points to a cloud-hosted Python worker.
# Format: host:port (no scheme prefix).
GRPC_AI_WORKER_ADDR=ai-worker.example.com:50051

# ─── Edge Mode ───────────────────────────────────────────────────────────────
# Signals the API to run in edge mode (skip local worker checks, etc.)
RAVEN_EDGE_MODE=true

# ─── Docker Image (optional, for pre-built images) ──────────────────────────
# RAVEN_API_IMAGE=ghcr.io/ravencloak-org/raven-api:latest-arm64

# ─── Domain / TLS (optional, for Traefik HTTPS) ─────────────────────────────
# DOMAIN=raven.local
# ACME_EMAIL=admin@example.com
