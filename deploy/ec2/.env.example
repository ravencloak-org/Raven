# ─── Raven EC2 Server Environment ───────────────────────────────────────────
# Copy to .env.server and fill in real values.
#
#   cp deploy/ec2/.env.example .env.server
#   nano .env.server

# ─── Domain ──────────────────────────────────────────────────────────────────
RAVEN_DOMAIN=raven.example.com

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=raven
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=raven
DATABASE_URL=postgresql://raven:CHANGE_ME_STRONG_PASSWORD@postgres:5432/raven?sslmode=disable

# ─── Valkey ───────────────────────────────────────────────────────────────────
VALKEY_URL=redis://valkey:6379/0

# ─── Keycloak ─────────────────────────────────────────────────────────────────
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD
KC_DB_URL=jdbc:postgresql://postgres:5432/keycloak
KC_DB_USERNAME=raven
KC_DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
KC_HOSTNAME=https://auth.raven.example.com
KC_HTTP_RELATIVE_PATH=/

# ─── Raven API ────────────────────────────────────────────────────────────────
RAVEN_SERVER_PORT=8080
RAVEN_DATABASE_URL=${DATABASE_URL}
RAVEN_VALKEY_URL=${VALKEY_URL}
RAVEN_GRPC_WORKER_ADDR=python-worker:50051

# ─── SeaweedFS ────────────────────────────────────────────────────────────────
SEAWEEDFS_FILER_URL=http://seaweedfs-filer:8888

# ─── OpenObserve ──────────────────────────────────────────────────────────────
ZO_ROOT_USER_EMAIL=admin@raven.local
ZO_ROOT_USER_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ─── AI Worker ────────────────────────────────────────────────────────────────
RAVEN_MEMORY_DIR=/var/raven/memories
RAVEN_ENABLE_WEB_SEARCH=false
ANTHROPIC_API_KEY=sk-ant-...

# ─── LLM Provider Keys ────────────────────────────────────────────────────────
# OPENAI_API_KEY=sk-...
# COHERE_API_KEY=...

# ─── PostHog (optional) ───────────────────────────────────────────────────────
# RAVEN_POSTHOG_API_KEY=phc_...

# ─── OpenTelemetry ────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://openobserve:5081

# ─── GHCR Image Tags ─────────────────────────────────────────────────────────
# Updated automatically by deploy/ec2/update.sh
GO_API_IMAGE=ghcr.io/ravencloak-org/go-api:latest
PYTHON_WORKER_IMAGE=ghcr.io/ravencloak-org/python-worker:latest
