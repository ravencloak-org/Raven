# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER={{ postgres_user }}
POSTGRES_PASSWORD={{ postgres_password }}
POSTGRES_DB={{ postgres_db }}
DATABASE_URL=postgresql://{{ postgres_user | urlencode }}:{{ postgres_password | urlencode }}@postgres:5432/{{ postgres_db }}?sslmode=disable

# ─── Valkey ───────────────────────────────────────────────────────────────────
VALKEY_URL=valkey:6379

# ─── Keycloak ─────────────────────────────────────────────────────────────────
KEYCLOAK_ADMIN={{ keycloak_admin }}
KEYCLOAK_ADMIN_PASSWORD={{ keycloak_admin_password }}
KC_DB_URL=jdbc:postgresql://postgres:5432/keycloak
KC_DB_USERNAME={{ postgres_user }}
KC_DB_PASSWORD={{ postgres_password }}
KC_HOSTNAME={{ keycloak_hostname }}

# ─── Raven API ────────────────────────────────────────────────────────────────
RAVEN_SERVER_PORT=8080
RAVEN_DATABASE_URL=${DATABASE_URL}
RAVEN_VALKEY_URL=${VALKEY_URL}
RAVEN_GRPC_WORKER_ADDR=python-worker:50051

# ─── SeaweedFS ────────────────────────────────────────────────────────────────
SEAWEEDFS_FILER_URL=http://seaweedfs-filer:8888

# ─── OpenObserve ──────────────────────────────────────────────────────────────
ZO_ROOT_USER_EMAIL={{ openobserve_email }}
ZO_ROOT_USER_PASSWORD={{ openobserve_password }}

# ─── AI Worker ────────────────────────────────────────────────────────────────
RAVEN_MEMORY_DIR=/var/raven/memories
RAVEN_ENABLE_WEB_SEARCH=false

# ─── LLM Provider (BYOK) ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY={{ anthropic_api_key }}

# ─── OpenTelemetry ────────────────────────────────────────────────────────────
RAVEN_OTEL_ENABLED=true
RAVEN_OTEL_ENDPOINT=openobserve:5081
OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic {{ (openobserve_email + ':' + openobserve_password) | b64encode }},organization=default

# ─── LiveKit ──────────────────────────────────────────────────────────────────
LIVEKIT_API_KEY={{ livekit_api_key }}
LIVEKIT_API_SECRET={{ livekit_api_secret }}
{# nosemgrep: javascript.lang.security.detect-insecure-websocket.detect-insecure-websocket -- dev-only placeholder; prod uses wss:// #}
RAVEN_LIVEKIT_HOST=ws://livekit-server:7880
RAVEN_LIVEKIT_API_KEY=${LIVEKIT_API_KEY}
RAVEN_LIVEKIT_API_SECRET=${LIVEKIT_API_SECRET}

# ─── Encryption ───────────────────────────────────────────────────────────────
RAVEN_ENCRYPTION_AES_KEY={{ encryption_aes_key }}
