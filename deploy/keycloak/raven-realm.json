{
  "realm": "raven",
  "displayName": "Raven Platform",
  "enabled": true,
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "sslRequired": "external",
  "accessTokenLifespan": 300,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "accessTokenLifespanForImplicitFlow": 300,
  "offlineSessionIdleTimeout": 1800,
  "roles": {
    "realm": [
      {
        "name": "platform_admin",
        "description": "Full platform administrator with access to all resources",
        "composite": false,
        "clientRole": false
      },
      {
        "name": "org_admin",
        "description": "Organization-level administrator",
        "composite": false,
        "clientRole": false
      },
      {
        "name": "user",
        "description": "Standard platform user",
        "composite": false,
        "clientRole": false
      }
    ]
  },
  "defaultRoles": ["user"],
  "clientScopes": [
    {
      "name": "raven-org",
      "description": "Raven organization context scope",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "true"
      },
      "protocolMappers": [
        {
          "name": "org_id",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "org_id",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "org_id",
            "jsonType.label": "String"
          }
        },
        {
          "name": "org_role",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "false",
            "user.attribute": "org_role",
            "id.token.claim": "false",
            "access.token.claim": "true",
            "claim.name": "org_role",
            "jsonType.label": "String"
          }
        },
        {
          "name": "workspace_ids",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "false",
            "user.attribute": "workspace_ids",
            "id.token.claim": "false",
            "access.token.claim": "true",
            "claim.name": "workspace_ids",
            "jsonType.label": "String",
            "multivalued": "true"
          }
        }
      ]
    }
  ],
  "clients": [
    {
      "clientId": "raven-web",
      "name": "Raven Web SPA",
      "description": "Vue.js single-page application for Raven platform",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "protocol": "openid-connect",
      "rootUrl": "http://localhost:3000",
      "baseUrl": "/",
      "redirectUris": [
        "http://localhost:3000/*",
        "http://localhost:8080/*"
      ],
      "webOrigins": [
        "http://localhost:3000",
        "http://localhost:8080"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "defaultClientScopes": [
        "openid",
        "profile",
        "email",
        "raven-org"
      ]
    },
    {
      "clientId": "raven-frontend",
      "name": "Raven Frontend (Production)",
      "description": "Vue.js SPA deployed on Cloudflare Pages",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "protocol": "openid-connect",
      "rootUrl": "https://raven-frontend.pages.dev",
      "baseUrl": "/",
      "redirectUris": [
        "https://raven-frontend.pages.dev/*"
      ],
      "webOrigins": [
        "+"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "defaultClientScopes": [
        "openid",
        "profile",
        "email",
        "raven-org"
      ]
    },
    {
      "clientId": "raven-api",
      "name": "Raven API Backend",
      "description": "Go backend service for Raven platform",
      "enabled": true,
      "publicClient": false,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "protocol": "openid-connect",
      "secret": "${RAVEN_API_CLIENT_SECRET}",
      "attributes": {},
      "defaultClientScopes": [
        "openid",
        "profile",
        "email",
        "raven-org"
      ]
    },
    {
      "clientId": "raven-chatbot",
      "name": "Raven Chatbot Widget",
      "description": "Public chatbot widget for embedding in external sites",
      "enabled": true,
      "publicClient": true,
      "bearerOnly": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "protocol": "openid-connect",
      "attributes": {},
      "defaultClientScopes": [
        "openid"
      ]
    }
  ],
  "browserSecurityHeaders": {
    "contentSecurityPolicy": "frame-src 'self'; frame-ancestors 'self'; object-src 'none';",
    "xContentTypeOptions": "nosniff",
    "xFrameOptions": "SAMEORIGIN",
    "xRobotsTag": "none",
    "xXSSProtection": "1; mode=block",
    "strictTransportSecurity": "max-age=31536000; includeSubDomains"
  }
}
