{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Raven Local",
  "version": "0.1.0",
  "identifier": "io.ravencloak.local",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devUrl": "desktop/src-tauri/splash.html",
    "frontendDist": "."
  },
  "app": {
    "windows": [
      {
        "title": "Raven Local",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "url": "splash.html"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "msi", "appimage", "deb"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["splash.html"]
  }
}
